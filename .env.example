# https://the-odds-api.com/
THE_ODDS_API_KEY=

# Neon Postgres — https://neon.tech/ (Connection string → Pooled)
DATABASE_URL=

# Default bankroll for cron/poll stake sizing
DEFAULT_TOTAL_STAKE=1000

# Local poller interval (seconds, min 5)
POLL_INTERVAL_SECONDS=30

# Protect GET /api/cron/poll-odds (Bearer token or x-cron-secret header)
CRON_SECRET=

# Telegram alerts — create bot via @BotFather, get chat id via @userinfobot or getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Don't re-alert same game within N minutes
ARB_NOTIFY_COOLDOWN_MINUTES=15

# Delete fetch_batches (and cascaded odds rows) older than N days; keeps manual_bets
RETENTION_DAYS_FETCH_BATCHES=14
